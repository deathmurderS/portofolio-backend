# ============================================
#  Portofolio Backend — Environment Variables
#  Salin file ini ke .env dan isi nilainya
# ============================================

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:nicetrynigga@localhost:5432/portofolio_db"

# Port backend (default: 3001)
PORT=3001

# URL frontend kamu (untuk CORS di production)
FRONTEND_URL="https://portofolio-green-xi.vercel.app/"
