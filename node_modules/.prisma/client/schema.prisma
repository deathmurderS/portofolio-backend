// ============================================
//  Portofolio Backend · Prisma Schema
//  Database: PostgreSQL
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Pesan dari form kontak ──────────────────
model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contacts")
}

// ── Data proyek yang ditampilkan ────────────
model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  emoji       String   @default("⭐")
  tags        String[] // Array of strings, e.g. ["React", "Tailwind"]
  demoUrl     String?
  githubUrl   String?
  thumbClass  String   @default("thumb-1") // thumb-1 / thumb-2 / thumb-3
  imageUrl    String?
  order       Int      @default(0)
  isVisible   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

// ── Visitor counter ─────────────────────────
model Visitor {
  id    Int      @id @default(autoincrement())
  date  DateTime @default(now()) @db.Date
  count Int      @default(1)

  @@unique([date])
  @@map("visitors")
}
